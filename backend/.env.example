# ─── DATABASE ─────────────────────────────────────────────────
# MongoDB Atlas connection string (free M0 cluster at mongodb.com)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/smritikana

# ─── SECURITY ─────────────────────────────────────────────────
# Secret key for admin API endpoints (x-admin-secret header)
# Change this to a strong random string before deploying!
ADMIN_SECRET=replace-with-a-strong-random-secret

# ─── EMAIL ────────────────────────────────────────────────────
# Gmail address used to send lead notification emails
EMAIL_USER=yourapp@gmail.com
# Gmail App Password (NOT your regular password)
# Enable 2FA on Gmail → Google Account → Security → App Passwords
EMAIL_PASS=your-gmail-app-password
# Email address that receives lead notifications (can be same as EMAIL_USER)
NOTIFY_EMAIL=admin@yourdomain.com

# ─── SERVER ───────────────────────────────────────────────────
PORT=5000
# Allowed origin for CORS (your frontend URL in production)
FRONTEND_URL=https://yourdomain.com

# ─── STOCK TICKER ─────────────────────────────────────────────
# How often (seconds) the background thread refreshes stock data
STOCK_REFRESH_SECS=60
