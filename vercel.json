{
    "version": 2,
    "builds": [
        {
            "src": "backend/app.py",
            "use": "@vercel/python"
        },
        {
            "src": "backend/public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "backend/app.py"
        },
        {
            "src": "/admin(.*)",
            "dest": "backend/app.py"
        },
        {
            "src": "/(.*)",
            "dest": "backend/public/$1"
        }
    ]
}